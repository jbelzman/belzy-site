---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  class?: string;
}

const { src, alt, caption = '', class: className = '' } = Astro.props;
---

<button
  type="button"
  class={`lb-trigger ${className}`}
  data-lightbox={src}
  data-lightbox-alt={alt}
  data-lightbox-caption={caption}
  aria-label={`Expand image: ${alt}`}
>
  <img src={src} alt={alt} loading="lazy" decoding="async" />
  <span class="lb-hint mono" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="14" height="14">
      <path d="M3 9 V3 H9 M21 9 V3 H15 M3 15 V21 H9 M21 15 V21 H15" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" />
    </svg>
    Expand
  </span>
</button>

<style>
  .lb-trigger {
    display: block;
    width: 100%;
    padding: 0;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: 4px;
    overflow: hidden;
    cursor: zoom-in;
    position: relative;
    transition: border-color var(--d-1) var(--ease), transform var(--d-2) var(--ease);
  }

  .lb-trigger:hover {
    border-color: var(--c-accent);
  }

  .lb-trigger img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform var(--d-3) var(--ease);
  }

  .lb-trigger:hover img {
    transform: scale(1.02);
  }

  .lb-hint {
    position: absolute;
    top: var(--s-3);
    right: var(--s-3);
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    padding: 0.375rem 0.625rem;
    background: rgba(11, 15, 26, 0.85);
    border: 1px solid var(--c-border-bright);
    border-radius: 2px;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-text);
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity var(--d-2) var(--ease), transform var(--d-2) var(--ease);
    pointer-events: none;
  }

  .lb-trigger:hover .lb-hint,
  .lb-trigger:focus-visible .lb-hint {
    opacity: 1;
    transform: translateY(0);
  }
</style>
