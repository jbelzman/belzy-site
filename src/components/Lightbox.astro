---
// Native <dialog>-based lightbox. Reads all [data-lightbox] images on the page.
---

<dialog id="lightbox" aria-label="Image viewer">
  <button class="lb-close" data-close aria-label="Close (Esc)">
    <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
      <path d="M6 6 L18 18 M18 6 L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none" />
    </svg>
  </button>
  <div class="lb-stage">
    <img id="lb-img" src="" alt="" />
  </div>
  <p class="lb-caption" id="lb-caption" aria-live="polite"></p>
</dialog>

<style>
  dialog#lightbox {
    border: 0;
    padding: 0;
    background: transparent;
    color: var(--c-text);
    max-width: 100vw;
    max-height: 100vh;
    width: 100vw;
    height: 100vh;
    margin: 0;
  }

  dialog#lightbox::backdrop {
    background: rgba(8, 11, 20, 0.92);
    backdrop-filter: blur(12px);
  }

  dialog#lightbox[open] {
    display: grid;
    grid-template-rows: 1fr auto;
    gap: var(--s-4);
    padding: var(--s-7) var(--s-5) var(--s-5);
    animation: lb-in var(--d-2) var(--ease);
  }

  @keyframes lb-in {
    from { opacity: 0; transform: scale(0.98); }
    to   { opacity: 1; transform: scale(1); }
  }

  .lb-stage {
    display: grid;
    place-items: center;
    overflow: auto;
    min-height: 0;
  }

  .lb-stage img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    border: 1px solid var(--c-border-bright);
    border-radius: 4px;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5);
  }

  .lb-close {
    position: fixed;
    top: var(--s-4);
    right: var(--s-4);
    background: var(--c-surface);
    border: 1px solid var(--c-border-bright);
    color: var(--c-text);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: all var(--d-1) var(--ease);
    z-index: 10;
  }

  .lb-close:hover {
    background: var(--c-accent);
    border-color: var(--c-accent);
  }

  .lb-caption {
    text-align: center;
    font-family: var(--f-mono);
    font-size: 0.8125rem;
    color: var(--c-text-mute);
    margin: 0;
    padding: 0 var(--s-5);
    max-width: 800px;
    margin-inline: auto;
  }

  .lb-caption:empty { display: none; }

  /* prevent body scroll when open */
  :global(html:has(dialog[open])) {
    overflow: hidden;
  }
</style>

<script>
  const dlg = document.getElementById('lightbox') as HTMLDialogElement | null;
  const img = document.getElementById('lb-img') as HTMLImageElement | null;
  const cap = document.getElementById('lb-caption');

  if (dlg && img && cap) {
    // open on trigger click
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const trigger = target.closest('[data-lightbox]') as HTMLElement | null;
      if (trigger) {
        e.preventDefault();
        const src = trigger.getAttribute('data-lightbox-src') || trigger.getAttribute('data-lightbox');
        const alt = trigger.getAttribute('data-lightbox-alt') || '';
        const caption = trigger.getAttribute('data-lightbox-caption') || '';
        if (src) {
          img.src = src;
          img.alt = alt;
          cap.textContent = caption;
          dlg.showModal();
        }
      }
      // close on backdrop click (event target is dialog itself)
      if (target === dlg) {
        dlg.close();
      }
      // close button
      if (target.closest('[data-close]')) {
        dlg.close();
      }
    });

    // clear src on close to free memory
    dlg.addEventListener('close', () => {
      img.src = '';
      img.alt = '';
      if (cap) cap.textContent = '';
    });
  }
</script>
