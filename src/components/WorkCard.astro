---
interface Props {
  href: string;
  client: string;
  role: string;
  years: string;
  summary: string;
  tools: string[];
  heroImage: string;
  heroAlt: string;
  index: number;
}

const { href, client, role, years, summary, tools, heroImage, heroAlt, index } = Astro.props;
const num = String(index).padStart(2, '0');
---

<a href={href} class="work-card">
  <div class="work-card-media">
    <img src={heroImage} alt={heroAlt} loading="lazy" decoding="async" />
    <span class="work-card-num mono">{num}</span>
  </div>
  <div class="work-card-body">
    <p class="eyebrow">{years} · {role}</p>
    <h3>{client}</h3>
    <p class="work-card-summary">{summary}</p>
    <ul class="work-card-tools mono">
      {tools.slice(0, 5).map((t) => <li>{t}</li>)}
    </ul>
    <span class="work-card-cta mono">
      Read case study <span class="arrow">→</span>
    </span>
  </div>
</a>

<style>
  .work-card {
    display: grid;
    grid-template-rows: auto 1fr;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: 4px;
    overflow: hidden;
    color: var(--c-text);
    transition: border-color var(--d-2) var(--ease), transform var(--d-2) var(--ease);
  }

  .work-card:hover {
    border-color: var(--c-accent);
    transform: translateY(-2px);
  }

  .work-card-media {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #F2F4F8;
    border-bottom: 1px solid var(--c-border);
  }

  .work-card-media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    padding: var(--s-3);
    transition: transform var(--d-3) var(--ease);
  }

  .work-card:hover .work-card-media img { transform: scale(1.03); }

  .work-card-num {
    position: absolute;
    top: var(--s-3);
    left: var(--s-3);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    color: var(--c-text-mute);
    background: rgba(11, 15, 26, 0.85);
    padding: 0.25rem 0.5rem;
    border-radius: 2px;
    border: 1px solid var(--c-border-bright);
  }

  .work-card-body {
    padding: var(--s-5) var(--s-5) var(--s-5);
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }

  .work-card-body h3 {
    font-size: 1.5rem;
    margin: 0;
  }

  .work-card-summary {
    color: var(--c-text-mute);
    font-size: 0.9375rem;
    margin: 0;
    flex: 1;
  }

  .work-card-tools {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .work-card-tools li {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-text-mute);
    border: 1px solid var(--c-border);
    padding: 0.25rem 0.5rem;
    border-radius: 2px;
  }

  .work-card-cta {
    font-size: 0.8125rem;
    color: var(--c-accent-2);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: var(--s-2);
  }

  .work-card-cta .arrow {
    display: inline-block;
    transition: transform var(--d-2) var(--ease);
  }

  .work-card:hover .work-card-cta .arrow { transform: translateX(4px); }
</style>
