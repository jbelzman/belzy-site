---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  pageType?: 'website' | 'article' | 'profile';
  noindex?: boolean;
}

const {
  title = 'Josh Belzman — Analytics & AI Enablement Leader',
  description = 'Director of Analytics at Publicis Media. I build measurement frameworks and AI-enabled workflows for $300M+ media programs.',
  ogImage = '/og.png',
  pageType = 'website',
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
const isHome = Astro.url.pathname === '/';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="dark" />
  <meta name="theme-color" content="#0B0F1A" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="canonical" href={canonical} />

  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex" />}

  <!-- Open Graph -->
  <meta property="og:type" content={pageType} />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="Josh Belzman" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- preconnect for fonts -->
  <link rel="preconnect" href="https://rsms.me" crossorigin />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  {isHome && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfilePage",
      "mainEntity": {
        "@type": "Person",
        "@id": "https://belzy.net/#josh",
        "name": "Josh Belzman",
        "jobTitle": "Director of Analytics",
        "url": "https://belzy.net",
        "image": "https://belzy.net/og.png",
        "worksFor": { "@type": "Organization", "name": "Publicis Media" },
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Savannah",
          "addressRegion": "GA",
          "addressCountry": "US"
        },
        "email": "mailto:josh@belzy.net",
        "sameAs": ["https://www.linkedin.com/in/jbelzman"],
        "knowsAbout": [
          "Analytics", "Business Intelligence", "Power BI", "Tableau",
          "Looker", "Measurement Frameworks", "AI Enablement",
          "Data Engineering", "SQL", "DAX"
        ]
      }
    })} />
  )}
</head>
<body>
  <a href="#main" class="skip">Skip to content</a>

  <header class="site-header">
    <div class="page header-inner">
      <a href="/" class="brand" aria-label="Josh Belzman, home">
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 40 40" width="32" height="32">
            <circle cx="20" cy="20" r="19" fill="#1E5BD8" />
            <path d="M 2 26 Q 20 16 38 14" stroke="#E63946" stroke-width="3" fill="none" stroke-linecap="round" />
            <text x="20" y="24" text-anchor="middle" font-family="Inter, sans-serif" font-weight="800" font-size="11" fill="white" letter-spacing="0.5">JOSH</text>
          </svg>
        </span>
        <span class="brand-name">Josh Belzman</span>
      </a>
      <nav class="site-nav" aria-label="Primary">
        <a href="/work" class={Astro.url.pathname.startsWith('/work') ? 'active' : ''}>Work</a>
        <a href="/resume" class={Astro.url.pathname === '/resume' ? 'active' : ''}>Resume</a>
        <a href="/contact" class={Astro.url.pathname === '/contact' ? 'active' : ''}>Contact</a>
      </nav>
    </div>
  </header>

  <main id="main">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="page footer-inner">
      <div class="footer-left">
        <p class="eyebrow">Josh Belzman · Savannah, GA</p>
        <p class="footer-tag">Analytics &amp; AI enablement leader. <a href="/contact">Let&rsquo;s talk →</a></p>
      </div>
      <div class="footer-right">
        <a href="mailto:josh@belzy.net">josh@belzy.net</a>
        <a href="https://www.linkedin.com/in/jbelzman" rel="me noopener" target="_blank">LinkedIn</a>
        <a href="/resume">Resume</a>
      </div>
      <p class="footer-meta mono">© {new Date().getFullYear()} · Built with Astro · Hosted on Netlify</p>
    </div>
  </footer>
</body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(12px);
    background: rgba(11, 15, 26, 0.7);
    border-bottom: 1px solid var(--c-border);
  }

  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--s-4);
    padding-bottom: var(--s-4);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--s-3);
    color: var(--c-text);
    font-weight: 500;
  }
  .brand:hover { color: var(--c-accent-2); }

  .brand-mark {
    display: inline-flex;
  }

  .brand-name {
    font-size: 0.9375rem;
    letter-spacing: -0.01em;
  }

  @media (max-width: 480px) {
    .brand-name { display: none; }
  }

  .site-nav {
    display: flex;
    gap: var(--s-6);
    font-family: var(--f-mono);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .site-nav a {
    color: var(--c-text-mute);
    position: relative;
    padding: var(--s-2) 0;
  }

  .site-nav a:hover, .site-nav a.active {
    color: var(--c-text);
  }

  .site-nav a.active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1px;
    background: var(--c-accent);
  }

  @media (max-width: 480px) {
    .site-nav { gap: var(--s-4); }
    .site-nav a { font-size: 0.75rem; }
  }

  /* ---------- footer ---------- */
  .site-footer {
    margin-top: var(--s-10);
    border-top: 1px solid var(--c-border);
    padding: var(--s-8) 0 var(--s-7);
    background:
      linear-gradient(to bottom, transparent, rgba(30, 91, 216, 0.04));
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--s-6);
    align-items: start;
  }

  .footer-left { grid-column: 1; }
  .footer-right {
    grid-column: 2;
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
    text-align: right;
  }

  .footer-right a {
    font-family: var(--f-mono);
    font-size: 0.875rem;
    color: var(--c-text-mute);
  }
  .footer-right a:hover { color: var(--c-accent-2); }

  .footer-tag {
    font-size: 1rem;
    margin-top: var(--s-2);
    color: var(--c-text);
  }
  .footer-tag a { color: var(--c-accent-2); }
  .footer-tag a:hover { color: var(--c-accent); }

  .footer-meta {
    grid-column: 1 / -1;
    margin-top: var(--s-6);
    padding-top: var(--s-5);
    border-top: 1px solid var(--c-border);
    font-size: 0.75rem;
    color: var(--c-text-dim);
  }

  @media (max-width: 640px) {
    .footer-inner { grid-template-columns: 1fr; }
    .footer-right {
      grid-column: 1;
      text-align: left;
      flex-direction: row;
      flex-wrap: wrap;
      gap: var(--s-4);
    }
  }
</style>
